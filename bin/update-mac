#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -P "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" >/dev/null 2>&1 && pwd)"

cd "$SCRIPT_DIR/.."

brew upgrade
brew bundle --upgrade

softwareupdate_list_output="$(softwareupdate --list 2>&1)"
should_restart=false

if grep -q "No new software available" <<< "$softwareupdate_list_output"; then
  echo "No macOS software updates available."
  exit 0
fi

if grep -q "Action: restart" <<< "$softwareupdate_list_output"; then
  echo "$softwareupdate_list_output"
  read -r -p "Restart? [y/N]: " restart_answer
  if [[ "$restart_answer" =~ ^[Yy]$ ]]; then
    should_restart=true
  fi
fi

softwareupdate_args=(--install --all)
if [[ "$should_restart" == true ]]; then
  softwareupdate_args+=(--restart)
fi

sudo softwareupdate "${softwareupdate_args[@]}"
